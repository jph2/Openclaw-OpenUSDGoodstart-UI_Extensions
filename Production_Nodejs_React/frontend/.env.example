# Copy this file to .env and adjust values as needed
# DO NOT commit .env to git (contains local configuration)

# Optional: direct backend URL (browser calls this host for /api).
# Leave unset for normal dev: same-origin /api → Vite proxy → backend on the SAME machine as Vite.
# Trap: ssh -L 5173:localhost:5173 to a laptop still runs Vite+API on the laptop — capture then looks
# for Linux Cursor paths. For IDE capture on a Windows PC, run Vite+backend locally on that PC.
# Set http://localhost:3000 only if the browser can reach the backend on that host (or forward :3000 too).
# VITE_API_BASE_URL=http://localhost:3000
